# MongoDB Connection URI
# Replace <username>, <password>, and the cluster domain with your MongoDB Atlas details.
# Make sure to specify the database name (e.g., /lankacv) before the query parameters.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/lankacv?retryWrites=true&w=majority

# Admin Portal Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

